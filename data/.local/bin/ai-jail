#!/bin/bash

# SECURITY NOTE: This file IS tracked by dotfiles (Git). It does NOT contain
# secrets — only deny-list names and mount logic. All sensitive data stays
# on the host filesystem and is blocked from the sandbox by the deny-lists below.
# Do NOT add API keys, tokens, passwords, or credentials to this file.
#
# ai-jail — bubblewrap sandbox for AI coding agents
# Mounts the project dir read-write, auto-discovers home dotfiles with a
# deny-list for sensitive dirs, and isolates namespaces.
#
# Usage: ai-jail [--no-jail] [--map PATH]... COMMAND [ARGS...]
#        ai-jail claude
#        ai-jail bash
#        ai-jail --no-jail COMMAND  # Bypass jail, exec directly

# ── Parse --no-jail flag ──────────────────────────────────────
# When --no-jail is the first argument, bypass the sandbox entirely
# and exec the command directly on the host. Useful for debugging,
# performance comparison, or when the jail causes issues.
if [[ "${1:-}" == "--no-jail" ]]; then
    shift
    echo "Jail Bypassed: executing directly" >&2
    exec "$@"
fi

PROJECT_DIR=$(pwd)
TEMP_HOSTS=$(mktemp /tmp/bwrap-hosts.XXXXXX)

trap 'rm -f "$TEMP_HOSTS"' EXIT

# ── Mise discovery ─────────────────────────────────────────────
REAL_MISE_BIN=$(type -p mise 2>/dev/null || echo "")

# ── Localhost fix (Go resolver needs /etc/hosts) ───────────────
printf '127.0.0.1 localhost ai-sandbox\n::1       localhost ai-sandbox\n' > "$TEMP_HOSTS"

# ── Parse --map / --rw-map arguments ─────────────────────────
# DANGER ZONE: User-provided paths are bound into the sandbox.
# EXTRA_MOUNTS runs INSIDE the jail — a malicious path could be
# used to escape via symlinks or expose unintended host files.
# Validate paths before passing them to ai-jail. Never pass
# untrusted input as --map argument.
EXTRA_MOUNTS=()
while [[ "${1:-}" == --map || "${1:-}" == --rw-map ]]; do
    FLAG="$1"
    MAP_PATH="$2"
    if [ -e "$MAP_PATH" ]; then
        if [[ "$FLAG" == "--rw-map" ]]; then
            EXTRA_MOUNTS+=("--bind" "$MAP_PATH" "$MAP_PATH")
        else
            EXTRA_MOUNTS+=("--ro-bind" "$MAP_PATH" "$MAP_PATH")
        fi
    else
        echo "Warning: Path $MAP_PATH not found, skipping." >&2
    fi
    shift 2
done

# ── Mise init command ──────────────────────────────────────────
# DANGER ZONE: eval executes arbitrary code emitted by the mise binary.
# If mise is compromised or a different binary is found first in PATH,
# this eval could run malicious code. Ensure mise comes from a trusted
# source and that PATH is not writable by untrusted users.
if [ -n "$REAL_MISE_BIN" ]; then
    MISE_INIT="$REAL_MISE_BIN trust && eval \"\$($REAL_MISE_BIN activate bash)\" && eval \"\$($REAL_MISE_BIN env)\""
else
    MISE_INIT="true"
fi

# ── NVM init command ──────────────────────────────────────────
# DANGER ZONE: NVM script sourced and executed inside the sandbox.
# NVM installs executables and modifies PATH. If NVM_DIR is tampered
# with, code inside nvm.sh could execute with sandbox permissions.
NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
NVM_INIT="true"
if [ -s "$NVM_DIR/nvm.sh" ]; then
    NVM_INIT="export NVM_DIR=\"$NVM_DIR\" && [ -s \"\$NVM_DIR/nvm.sh\" ] && \\. \"\$NVM_DIR/nvm.sh\" && [ -s \"\$NVM_DIR/bash_completion\" ] && \\. \"\$NVM_DIR/bash_completion\""
fi

# DANGER ZONE: The deny-lists below define the ENTIRE security boundary
# of the sandbox. Adding a directory to DOTDIR_RW grants it read-write
# access from inside the jail. Removing a directory from DOTDIR_DENY
# makes it visible to the agent. Changes here directly impact what
# secrets the sandbox can expose. Review every addition/removal carefully.
# ── Dotfile deny-list (never mounted — sensitive data) ─────────
DOTDIR_DENY=(.gnupg .aws .mozilla .basilisk-dev .sparrow .ssh .steam .pki .var .android .gemini .ollama)

# Subdirs of ~/.config to hide (tmpfs over rw config mount)
CONFIG_DENY=(BraveSoftware Bitwarden google-chrome google-chrome-for-testing discord Discord gh Pinokio warp-terminal obsidian Docker Desktop Code)

# Subdirs of ~/.cache to hide (sensitive browser/app caches)
CACHE_DENY=(BraveSoftware basilisk-dev chromium spotify nvidia mesa_shader_cache google-chrome)

# Dotdirs requiring read-write access
DOTDIR_RW=(.claude .crush .codex .aider .config .cargo .cache .docker .nvm)

# ── Helper functions ───────────────────────────────────────────
is_denied() {
    local name="$1"
    for d in "${DOTDIR_DENY[@]}"; do [[ "$name" == "$d" ]] && return 0; done
    return 1
}

is_rw() {
    local name="$1"
    for d in "${DOTDIR_RW[@]}"; do [[ "$name" == "$d" ]] && return 0; done
    return 1
}

# ── Symlink target resolution ──────────────────────────────────
# If entry is a symlink pointing inside PROJECT_DIR, return 0 and
# set SYMLINK_TARGET to the resolved absolute path. Used by both
# directory and file mounts to preserve symlink metadata in sandbox.
resolve_symlink_target() {
    local entry="$1"
    if [ -L "$entry" ]; then
        local target
        target=$(readlink -f "$entry" 2>/dev/null) || return 1
        [[ "$target" == "$PROJECT_DIR"* ]] || return 1
        SYMLINK_TARGET="$target"
        return 0
    fi
    return 1
}

# Entries whose symlink target is inside PROJECT_DIR are recreated
# as --symlink in the sandbox instead of bind-mounting (which resolves
# the symlink and loses the metadata). Collected here and appended
# after the PROJECT_DIR bind mount.
SYMLINK_REPLACEMENTS=()

# ── Auto-discover dot-directories in $HOME ─────────────────────
# Only directories — regular dotfiles (e.g. .claude.json) are NOT mounted.
# The tmpfs $HOME is writable so tools can create dotfiles as needed.
DOTFILE_MOUNTS=()
for entry in "$HOME"/.*; do
    [ -d "$entry" ] || continue
    name=$(basename "$entry")
    [[ "$name" == "." || "$name" == ".." ]] && continue
    is_denied "$name" && continue

    # Symlink pointing inside PROJECT_DIR? Preserve as --symlink
    if resolve_symlink_target "$entry"; then
        SYMLINK_REPLACEMENTS+=("--symlink" "$SYMLINK_TARGET" "$entry")
        continue
    fi

    if is_rw "$name"; then
        DOTFILE_MOUNTS+=("--bind" "$entry" "$HOME/$name")
    else
        DOTFILE_MOUNTS+=("--ro-bind" "$entry" "$HOME/$name")
    fi
done

# ── Explicit dotfile mounts (regular files) ────────────────────
# Symlink detection applies here too: if .gitconfig is a symlink
# pointing into PROJECT_DIR, preserve it rather than resolving.
if resolve_symlink_target "$HOME/.gitconfig"; then
    SYMLINK_REPLACEMENTS+=("--symlink" "$SYMLINK_TARGET" "$HOME/.gitconfig")
elif [ -f "$HOME/.gitconfig" ]; then
    DOTFILE_MOUNTS+=("--ro-bind" "$HOME/.gitconfig" "$HOME/.gitconfig")
fi

if resolve_symlink_target "$HOME/.claude.json"; then
    SYMLINK_REPLACEMENTS+=("--symlink" "$SYMLINK_TARGET" "$HOME/.claude.json")
elif [ -f "$HOME/.claude.json" ]; then
    DOTFILE_MOUNTS+=("--bind" "$HOME/.claude.json" "$HOME/.claude.json")
fi

# ── Dotfiles repo (resolves symlinks from ~/dotfiles) ────────
DOTFILE_MOUNTS+=("--ro-bind" "$HOME/dotfiles" "$HOME/dotfiles")

# ── Hide sensitive subdirs inside ~/.config (after rw mount) ───
CONFIG_HIDE_MOUNTS=()
for denied in "${CONFIG_DENY[@]}"; do
    [ -d "$HOME/.config/$denied" ] && CONFIG_HIDE_MOUNTS+=("--tmpfs" "$HOME/.config/$denied")
done

# ── Hide sensitive subdirs inside ~/.cache (after rw mount) ──
CACHE_HIDE_MOUNTS=()
for denied in "${CACHE_DENY[@]}"; do
    [ -d "$HOME/.cache/$denied" ] && CACHE_HIDE_MOUNTS+=("--tmpfs" "$HOME/.cache/$denied")
done

# ── Override ~/.local subdirs as rw (parent .local is ro) ──────
LOCAL_OVERRIDES=()
[ -d "$HOME/.local/state" ] && LOCAL_OVERRIDES+=("--bind" "$HOME/.local/state" "$HOME/.local/state")
for rw_share in zoxide crush opencode atuin mise yarn flutter kotlin NuGet pipx ruby-advisory-db uv pnpm; do
    [ -d "$HOME/.local/share/$rw_share" ] && LOCAL_OVERRIDES+=("--bind" "$HOME/.local/share/$rw_share" "$HOME/.local/share/$rw_share")
done

# ── Hide sensitive subdirs inside ~/.local/share (tmpfs over rw overrides) ──
LOCAL_HIDE=()
for denied in keyrings kwalletd; do
    [ -d "$HOME/.local/share/$denied" ] && LOCAL_HIDE+=("--tmpfs" "$HOME/.local/share/$denied")
done

# ── GPU device mounts (NVIDIA + DRM) ─────────────────────────
GPU_MOUNTS=()
for dev in /dev/nvidia* /dev/dri; do
    [ -e "$dev" ] && GPU_MOUNTS+=("--dev-bind" "$dev" "$dev")
done

# SECURITY NOTE: Mounting the Docker socket gives the sandbox full
# access to the host's Docker daemon. Any process inside the jail
# can create privileged containers or access Docker volumes that may
# contain sensitive data. Remove this block if the agent does not
# need Docker access.
# ── Docker socket ────────────────────────────────────────────
DOCKER_MOUNT=()
[ -S /var/run/docker.sock ] && DOCKER_MOUNT+=("--bind" "/var/run/docker.sock" "/var/run/docker.sock")

# ── Shared memory (Chromium needs large /dev/shm) ───────────
SHM_MOUNT=()
[ -d /dev/shm ] && SHM_MOUNT+=("--dev-bind" "/dev/shm" "/dev/shm")

# ── Display passthrough (X11 + Wayland) ─────────────────────
DISPLAY_MOUNTS=()
DISPLAY_ENV=()

# X11 / XWayland socket
[ -d /tmp/.X11-unix ] && DISPLAY_MOUNTS+=("--bind" "/tmp/.X11-unix" "/tmp/.X11-unix")
[ -n "${DISPLAY:-}" ] && DISPLAY_ENV+=("--setenv" "DISPLAY" "$DISPLAY")
[ -n "${XAUTHORITY:-}" ] && {
    DISPLAY_MOUNTS+=("--ro-bind" "$XAUTHORITY" "$XAUTHORITY")
    DISPLAY_ENV+=("--setenv" "XAUTHORITY" "$XAUTHORITY")
}

# Wayland socket (lives in XDG_RUNTIME_DIR, typically /run/user/UID)
if [ -n "${XDG_RUNTIME_DIR:-}" ] && [ -d "$XDG_RUNTIME_DIR" ]; then
    DISPLAY_MOUNTS+=("--bind" "$XDG_RUNTIME_DIR" "$XDG_RUNTIME_DIR")
    DISPLAY_ENV+=("--setenv" "XDG_RUNTIME_DIR" "$XDG_RUNTIME_DIR")
    [ -n "${WAYLAND_DISPLAY:-}" ] && DISPLAY_ENV+=("--setenv" "WAYLAND_DISPLAY" "$WAYLAND_DISPLAY")
fi

# ── Assemble and launch ───────────────────────────────────────
echo "Jail Active: $PROJECT_DIR"

bwrap \
  --ro-bind /usr /usr \
  --ro-bind /bin /bin \
  --ro-bind /lib /lib \
  --ro-bind /lib64 /lib64 \
  --ro-bind /etc /etc \
  --ro-bind "$TEMP_HOSTS" /etc/hosts \
  --ro-bind /opt /opt \
  --ro-bind /sbin /sbin \
  --ro-bind /sys /sys \
  --dev /dev \
  "${GPU_MOUNTS[@]}" \
  "${SHM_MOUNT[@]}" \
  --proc /proc \
  --tmpfs /tmp \
  --tmpfs /run \
  "${DOCKER_MOUNT[@]}" \
  "${DISPLAY_MOUNTS[@]}" \
  --tmpfs "$HOME" \
  "${DOTFILE_MOUNTS[@]}" \
  "${CONFIG_HIDE_MOUNTS[@]}" \
  "${CACHE_HIDE_MOUNTS[@]}" \
  "${LOCAL_OVERRIDES[@]}" \
  "${LOCAL_HIDE[@]}" \
  "${EXTRA_MOUNTS[@]}" \
  --bind "$PROJECT_DIR" "$PROJECT_DIR" \
  "${SYMLINK_REPLACEMENTS[@]}" \
  --chdir "$PROJECT_DIR" \
  --die-with-parent \
  --unshare-pid \
  --unshare-uts \
  --unshare-ipc \
  --hostname "ai-sandbox" \
  "${DISPLAY_ENV[@]}" \
  --setenv PS1 "(jail) \w \$ " \
  --setenv _ZO_DOCTOR 0 \
  bash -c "$MISE_INIT && $NVM_INIT && ${*:-bash}"
