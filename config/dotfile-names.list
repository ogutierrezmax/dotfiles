# Nomes dos dotfiles a instalar (um por linha, relativos a data/).
# Cada nome vira um symlink em ~: sem ponto → ~/.nome; com ponto (ex.: .zsh) → ~/.zsh
# Linhas vazias e linhas que começam com # são ignoradas.


# Teste wrong_target: symlink em ~/.wronglink-test deve apontar para outro sítio (ex.: /etc/hostname).

gitconfig
.zshrc
.agents
.zsh

# Cursor
.config/Cursor/User/keybindings.json
.config/Cursor/User/settings.json

# KDE Plasma configs
kde-plasma/.config/kdeglobals
kde-plasma/.config/kwinrc
kde-plasma/.config/kwinrulesrc
kde-plasma/.config/kglobalshortcutsrc
kde-plasma/.config/plasmashellrc
# plasma-org.kde.plasma.desktop-appletsrc é gerenciado pelo sistema de presets de tema.
# Não é mais um symlink. Use: data/kde-plasma/themes/switch-theme.sh <nome-do-tema>
.tmux.conf

# Autostart
.config/autostart/alfocards.desktop
.config/autostart/Hydration Tracker.desktop
.config/autostart/obsidian.desktop
.config/autostart/plasma-panel-lang-color.desktop
